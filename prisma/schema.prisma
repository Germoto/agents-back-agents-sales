generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  OPERATOR
}

enum ProductType {
  DIGITAL
  PHYSICAL
}

enum PaymentMode {
  BEFORE_DELIVERY
  CASH_ON_DELIVERY
  MANUAL
}

enum ConversationRole {
  USER
  ASSISTANT
  ADMIN
  SYSTEM
}

enum OrderStatus {
  PEDIDO_REGISTRADO
  EN_COORDINACION
  DESPACHADO
  CANCELADO
}

enum DigitalSaleStatus {
  ESPERANDO_PAGO
  COMPROBANTE_RECIBIDO
  PAGO_RECHAZADO
  ENTREGADO
  CANCELADO
}

enum ReceiptStatus {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
}

enum ProductFileType {
  IMAGE
  PDF
  VIDEO
  AUDIO
  OTHER
}

// Rubro / vertical del negocio. Fase 1 solo cabea INFOPRODUCT; el resto queda
// listo en el modelo de datos para fases posteriores.
enum BusinessVertical {
  INFOPRODUCT
  PHYSICAL_GOODS
  RESTAURANT
  STREAMER
  SERVICE
  OTHER
}

// Estado de una conversación viva del agente con un cliente.
enum ConversationStatus {
  OPEN
  HUMAN
  CLOSED
}

// Estado del carrito multi-producto.
enum CartStatus {
  OPEN
  CHECKED_OUT
  ABANDONED
}

// Tipos de recordatorio/seguimiento programado.
enum ScheduledMessageType {
  ABANDONED_CART
  LEFT_ON_READ
  OFFER_COUNTDOWN
  POST_SALE
  CUSTOM
  FLOW_TIMEOUT
}

enum ScheduledMessageStatus {
  PENDING
  SENT
  CANCELLED
  FAILED
}

// Estado de una reserva de servicio (rubro SERVICE).
enum ServiceBookingStatus {
  SOLICITADA
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

model Company {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  slug              String                @unique
  adminPhone        String
  vertical          BusinessVertical      @default(INFOPRODUCT)
  // Config de entrega a nivel negocio (restaurante/físico): { cost, time, areas[],
  // pickupAvailable, requiresAddress }. El agente la usa para todos los productos.
  deliveryConfig    Json?
  timezone          String                @default("America/Lima")
  // Modo de operación del bot: "AI" (agente IA abierto) | "FLOW" (chatbot de
  // flujos guiados). Excluyentes: en modo FLOW el agente IA no responde.
  botMode           String                @default("AI")
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  users             User[]
  agentConfig       AgentConfig?
  whatsappConfig    WhatsappConfig?
  paymentConfig     PaymentConfig?
  products          Product[]
  customers         Customer[]
  messages          ConversationMessage[]
  conversations     Conversation[]
  carts             Cart[]
  scheduledMessages ScheduledMessage[]
  serviceBookings   ServiceBooking[]
  orders            Order[]
  digitalSales      DigitalSale[]
  paymentReceipts   PaymentReceipt[]
  webhookEndpoints  WebhookEndpoint[]
  quickReplies         QuickReply[]
  quickReplyCategories QuickReplyCategory[]
  crms                 Crm[]
  crmColumns           CrmColumn[]
  crmCards             CrmCard[]
  customerTags         CustomerTag[]
  customerDeals        CustomerDeal[]
  chatFlows            ChatFlow[]
}

// Config singleton a nivel plataforma (no por tenant). Hoy guarda los rubros
// habilitados globalmente: el selector de rubro de cada cliente solo muestra
// estos. Fila única con id="global".
model PlatformConfig {
  id               String             @id @default("global")
  enabledVerticals BusinessVertical[]
  updatedAt        DateTime           @updatedAt
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @db.Uuid
  name         String
  phone        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AgentConfig {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @unique @db.Uuid
  openaiModel    String   @default("gpt-4o-mini")
  openaiApiKey   String?
  temperature    Decimal  @default(0.25) @db.Decimal(4, 2)
  basePrompt     String
  salesStyle     String
  rules          Json
  // Config de recordatorios/seguimientos (horas de abandono, dejado en visto,
  // ventana de timer de oferta, plantillas). Null = usar defaults del agente.
  followupConfig Json?
  // Modo de respuesta del agente: "OPEN" responde a todos; "ALLOWLIST" solo a
  // los números en testNumbers (modo prueba). Default OPEN.
  replyMode      String   @default("OPEN")
  testNumbers    Json?    // array de teléfonos permitidos cuando replyMode=ALLOWLIST
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model WhatsappConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String   @unique @db.Uuid
  apiUrl          String
  secret          String
  account         String?  @unique
  defaultServerId Int?
  smsToolsUserId  Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model PaymentConfig {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String          @unique @db.Uuid
  enabled           Boolean         @default(true)
  paymentMode       PaymentMode
  notificationPhone String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  methods           PaymentMethod[]
}

model PaymentMethod {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentConfigId String        @db.Uuid
  method          String
  number          String
  holder          String
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paymentConfig   PaymentConfig @relation(fields: [paymentConfigId], references: [id], onDelete: Cascade)

  @@index([paymentConfigId, sortOrder])
}

model Product {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String                @db.Uuid
  slug             String
  active           Boolean               @default(true)
  // Visibilidad en el catálogo. Un producto puede estar activo (vendible) pero
  // oculto del catálogo: solo se ofrece como relacionado (cross-sell) o si lo nombran.
  showInCatalog    Boolean               @default(true)
  productType      ProductType
  name             String
  price            String
  regularPrice     String?
  stock            Int?
  shortDescription String
  fullDescription  String
  // Mensaje de presentación que el bot envía TAL CUAL al presentar el producto
  // (si está vacío, el bot arma la ficha con los campos estructurados).
  presentationMessage String?
  deliveryMethod   String?
  support          String?
  // Atributos flexibles libres por rubro (clave→valor). Complemento opcional.
  attributes       Json?
  // Categoría/sección para agrupar el catálogo (restaurante: "Entradas";
  // streaming: la plataforma "Netflix"). Opcional.
  category         String?
  // Datos estructurados del rubro (vertical pack), validados por schema según
  // Company.vertical. Ej. streaming: { billingPeriod, tier, screens, quality }.
  verticalData     Json?
  // Override opcional de recordatorios por producto y por tipo:
  // { <tipo>: { message?, mediaUrl? } }. Si existe, gana sobre la plantilla del negocio.
  reminderConfig   Json?
  sortOrder        Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  company          Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aliases          ProductAlias[]
  benefits         ProductBenefit[]
  includes         ProductInclude[]
  bonuses          ProductBonus[]
  faqs             ProductFaq[]
  objections       ProductObjection[]
  files            ProductFile[]
  digitalDelivery  DigitalDelivery?
  physicalDelivery PhysicalDelivery?
  variants         ProductVariant[]
  customers        Customer[]
  messages         ConversationMessage[]
  cartItems        CartItem[]
  orders           Order[]
  digitalSales     DigitalSale[]
  paymentReceipts  PaymentReceipt[]
  serviceBookings  ServiceBooking[]

  @@unique([companyId, slug])
  @@index([companyId, active, sortOrder])
}

model ProductAlias {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  value     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductBenefit {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  value     String
  sortOrder Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductInclude {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  value     String
  sortOrder Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductBonus {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  value     String
  sortOrder Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductFaq {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  question  String
  answer    String
  sortOrder Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductObjection {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  question  String
  answer    String
  sortOrder Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductFile {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String          @db.Uuid
  type         ProductFileType
  url          String
  storagePath  String          @default("")
  originalName String          @default("")
  extension    String          @default("")
  mimeType     String          @default("")
  size         Int             @default(0)
  description  String          @default("")
  sortOrder    Int             @default(0)
  // Si true, el archivo se incluye en la presentación/info inicial del producto
  // (envío bulk). Si false, queda disponible solo on-demand (el bot lo manda por
  // fileIds cuando el cliente lo pide o la consulta se relaciona con él).
  showInPresentation Boolean    @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model DigitalDelivery {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String  @unique @db.Uuid
  link         String
  instructions String
  // Mensajes adicionales opcionales tras la entrega: array de {message,mediaUrl,mediaType}.
  followupMessages  Json    @default("[]")
  // Legacy (single) — conservados por compat; el array de arriba es la fuente de verdad.
  followupMessage   String  @default("")
  followupMediaUrl  String  @default("")
  followupMediaType String  @default("")
  // Producto a ofrecer (cross-sell) tras entregar; se resuelve contra el catálogo
  // en runtime (sin FK formal: si el producto se borra, se ignora).
  crossSellProductId String? @db.Uuid
  // Mensaje con el que se ofrece el relacionado. Vacío => línea automática.
  crossSellPitch     String  @default("")
  // Multimedia opcional del mensaje de enganche (se envía con el pitch como caption).
  crossSellPitchMediaUrl  String @default("")
  crossSellPitchMediaType String @default("")
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PhysicalDelivery {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String  @unique @db.Uuid
  requiresAddress Boolean @default(true)
  deliveryCost    String?
  deliveryTime    String?
  pickupAvailable Boolean @default(false)
  deliveryAreas   Json
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @db.Uuid
  name      String
  options   Json
  sortOrder Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Customer {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String                @db.Uuid
  phone             String
  name              String?
  email             String?
  status            String
  selectedProductId String?               @db.Uuid
  lastInteractionAt DateTime
  metadata          Json
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  selectedProduct   Product?              @relation(fields: [selectedProductId], references: [id], onDelete: SetNull)
  messages          ConversationMessage[]
  conversations     Conversation[]
  carts             Cart[]
  scheduledMessages ScheduledMessage[]
  serviceBookings   ServiceBooking[]
  orders            Order[]
  digitalSales      DigitalSale[]
  paymentReceipts   PaymentReceipt[]
  crmCards          CrmCard[]
  tagLinks          CustomerTagLink[]
  deals             CustomerDeal[]

  @@unique([companyId, phone])
  @@index([companyId, lastInteractionAt])
}

model ConversationMessage {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String           @db.Uuid
  customerId     String           @db.Uuid
  conversationId String?          @db.Uuid
  productId      String?          @db.Uuid
  role           ConversationRole
  message        String?
  mediaUrl       String?
  // Tipo del adjunto ("image"|"video"|"audio"|"document") para render correcto en
  // el panel; null en históricos o texto (el frontend infiere por extensión).
  mediaType      String?
  rawPayload     Json?
  // Tracking de entrega vía gateway WhatsApp (SMS Tools). gatewayId = messageId del
  // envío; deliveryStatus: null=no rastreado, "pending"|"sent"|"failed".
  gatewayId       String?
  deliveryStatus  String?
  deliveryRetries Int             @default(0)
  createdAt      DateTime         @default(now())
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation   Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  product        Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId, customerId, createdAt])
  @@index([conversationId, createdAt])
  @@index([deliveryStatus, createdAt])
}

// Conversación viva del agente con un cliente (reemplaza el staticData de n8n).
// `state` guarda el equivalente al customer.* del workflow: selectedProductId,
// flags de pago, lastPaymentPromptAt, pendingAction, etc.
model Conversation {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String                @db.Uuid
  customerId    String                @db.Uuid
  channel       String                @default("whatsapp")
  status        ConversationStatus    @default(OPEN)
  state         Json                  @default("{}")
  lastInboundId String? // id del último mensaje de SMS Tools (idempotencia)
  botPaused     Boolean               @default(false)
  openedAt      DateTime              @default(now())
  lastMessageAt DateTime              @default(now())
  closedAt      DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages      ConversationMessage[]

  @@unique([companyId, customerId, channel])
  @@index([companyId, lastMessageAt])
}

// Categoría de respuestas rápidas (estilo etiquetas de Google Keep, por tenant).
model QuickReplyCategory {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String       @db.Uuid
  name         String
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quickReplies QuickReply[]

  @@unique([companyId, name])
  @@index([companyId, sortOrder])
}

// Respuesta rápida del panel de conversaciones: secuencia ordenada de mensajes
// (texto/imagen/video/audio/documento) que el admin envía con un click.
// `messages`: [{ type: "text"|"image"|"video"|"audio"|"document", text?, mediaUrl?, fileName? }]
model QuickReply {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String              @db.Uuid
  categoryId String?             @db.Uuid
  title      String
  messages   Json
  usageCount Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   QuickReplyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([companyId, updatedAt])
}

// ---------------------------------------------------------------------------
// CRM kanban: tableros (Crm) con columnas (CrmColumn) y placements (CrmCard).
// El "Inbox" del tablero es virtual: clientes con conversación SIN CrmCard en
// ese CRM. Un cliente puede estar en columnas distintas en CRMs distintos.
// ---------------------------------------------------------------------------

model Crm {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String      @db.Uuid
  name        String
  description String?
  color       String      @default("#6366f1")
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  columns     CrmColumn[]
  cards       CrmCard[]

  @@unique([companyId, name])
  @@index([companyId, sortOrder])
}

model CrmColumn {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crmId     String    @db.Uuid
  companyId String    @db.Uuid
  name      String
  color     String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  crm       Crm       @relation(fields: [crmId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cards     CrmCard[]

  @@index([crmId, sortOrder])
}

model CrmCard {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String    @db.Uuid
  crmId      String    @db.Uuid
  columnId   String    @db.Uuid
  customerId String    @db.Uuid
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  crm        Crm       @relation(fields: [crmId], references: [id], onDelete: Cascade)
  column     CrmColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([crmId, customerId])
  @@index([columnId, sortOrder])
}

// Etiquetas internas de clientes (no hay acceso a etiquetas de WA Business).
model CustomerTag {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String            @db.Uuid
  name      String
  color     String            @default("#22c55e")
  createdAt DateTime          @default(now())
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  links     CustomerTagLink[]

  @@unique([companyId, name])
}

model CustomerTagLink {
  customerId String      @db.Uuid
  tagId      String      @db.Uuid
  createdAt  DateTime    @default(now())
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag        CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@index([tagId])
}

// "Valor del negocio": montos manuales por cliente que suman al total de la
// tarjeta del CRM (además de los PaymentReceipt aprobados).
model CustomerDeal {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @db.Uuid
  customerId  String   @db.Uuid
  description String
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId, customerId])
}

// Flujo guiado de chatbot (alternativa al agente IA; Company.botMode = "FLOW").
// nodes/edges en formato React Flow; trigger = disparadores del flujo.
model ChatFlow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @db.Uuid
  name        String
  description String   @default("")
  isActive    Boolean  @default(false)
  trigger     Json     @default("{}")
  nodes       Json     @default("[]")
  edges       Json     @default("[]")
  viewport    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

// Carrito multi-producto. Al cerrar la venta se poblan PaymentReceipt.productIds.
model Cart {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String     @db.Uuid
  customerId String     @db.Uuid
  status     CartStatus @default(OPEN)
  totalText  String?
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]

  @@index([companyId, status])
  @@index([customerId, status])
}

model CartItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId         String   @db.Uuid
  productId      String   @db.Uuid
  quantity       Int      @default(1)
  variantChoices Json?
  unitPriceText  String?
  createdAt      DateTime @default(now())
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Sin unique(cartId,productId): el mismo plato puede ir varias veces con
  // distintos modificadores (variantChoices) como líneas separadas.
  @@index([cartId])
  @@index([cartId, productId])
}

// Recordatorios/seguimientos programados. El worker node-cron escanea
// (status, sendAt) cada minuto y los envía vía SMS Tools.
model ScheduledMessage {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String                 @db.Uuid
  customerId     String                 @db.Uuid
  conversationId String?                @db.Uuid
  type           ScheduledMessageType
  status         ScheduledMessageStatus @default(PENDING)
  sendAt         DateTime
  sentAt         DateTime?
  body           String
  mediaUrl       String?
  metadata       Json?
  failureReason  String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  company        Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([status, sendAt])
  @@index([companyId, customerId, status])
}

// Reserva ligera de un servicio (rubro SERVICE). El horario solicitado se guarda
// como texto (lo que pidió el cliente); el admin coordina/confirma el detalle.
model ServiceBooking {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String               @db.Uuid
  customerId    String               @db.Uuid
  productId     String               @db.Uuid
  requestedText String               // p.ej. "este sábado 4pm"
  modality      String?              // presencial | online | ...
  status        ServiceBookingStatus @default(SOLICITADA)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model Order {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String      @db.Uuid
  customerId   String      @db.Uuid
  productId    String      @db.Uuid
  orderCode    String      @unique
  quantity     Int
  customerName String
  address      String
  reference    String
  notes        String?
  status       OrderStatus
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model DigitalSale {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String            @db.Uuid
  customerId     String            @db.Uuid
  productId      String            @db.Uuid
  amountExpected String
  status         DigitalSaleStatus
  deliveredAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  receipts       PaymentReceipt[]

  @@index([companyId, createdAt])
}

model PaymentReceipt {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId             String         @db.Uuid
  customerId            String?        @db.Uuid
  productId             String?        @db.Uuid
  productIds            String[]       @default([]) @db.Uuid
  orderId               String?
  digitalSaleId         String?        @db.Uuid
  mediaUrl              String?
  amountExpected        String // mantenido por compatibilidad; mirror de amountPaid
  amountPaid            String? // monto realmente recibido del origen
  currency              String         @default("PEN")
  status                ReceiptStatus
  rejectionReason       String?
  source                String? // "validpay", "manual", etc.
  externalId            String? // id del pago en el sistema externo (idempotencia)
  payerName             String? // nombre del pagador reportado por el origen
  paymentSource         String? // "yape", "plin", "transferencia", etc.
  payerPhone            String? // teléfono o últimos dígitos si el origen los emite
  operationCode         String? // código de operación bancaria si aplica
  reference             String? // referencia libre del origen
  occurredAt            DateTime? // momento en que ocurrió el pago según el origen
  validatedAt           DateTime? // momento en que se aprobó/rechazó
  validationNote        String? // nota libre de quien validó (n8n / admin)
  validationMode        String? // "AUTO" | "MANUAL"
  matchScore            Int? // 0-100 score con que n8n lo cerró
  matchStrategy         String? // ej: "amount_name_time"
  matchedPayerNameInput String? // nombre que envió el cliente vs el del comprobante
  metadata              Json? // extras: conversationKey, waPhone, cartTotal, expectedAmount, etc.
  claimedBy             String? // identificador de la ejecución n8n que reclamó el pago
  claimedUntil          DateTime? // timestamp hasta el cual el claim es válido
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  company               Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer              Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product               Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  digitalSale           DigitalSale?   @relation(fields: [digitalSaleId], references: [id], onDelete: SetNull)
  webhookEvents         WebhookEvent[]

  @@unique([source, externalId])
  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
  @@index([companyId, amountPaid])
  @@index([companyId, occurredAt])
}

model WebhookEndpoint {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String    @db.Uuid
  source         String // "validpay", "mercadopago", "custom"
  secret         String // plain text (almacenado en zona de confianza, igual que Stripe)
  active         Boolean   @default(true)
  autoApprove    Boolean   @default(true)
  description    String?
  validpayApiKey String? // API Key de ValidPay para notificar de vuelta al aprobar (source=validpay)
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  events  WebhookEvent[]

  @@index([companyId])
  @@map("webhook_endpoints")
}

model WebhookEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  endpointId String   @db.Uuid
  companyId  String   @db.Uuid
  source     String
  externalId String
  eventType  String   @default("")
  payload    Json
  status     String // RECEIVED, PROCESSED, FAILED, DUPLICATE
  error      String?
  receiptId  String?  @db.Uuid
  receivedAt DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  receipt  PaymentReceipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@unique([source, externalId, eventType])
  @@index([companyId, receivedAt])
  @@map("webhook_events")
}
