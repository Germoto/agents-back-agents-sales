generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  OPERATOR
}

enum ProductType {
  DIGITAL
  PHYSICAL
}

enum PaymentMode {
  BEFORE_DELIVERY
  CASH_ON_DELIVERY
  MANUAL
}

enum ConversationRole {
  USER
  ASSISTANT
  ADMIN
  SYSTEM
}

enum OrderStatus {
  PEDIDO_REGISTRADO
  EN_COORDINACION
  DESPACHADO
  CANCELADO
}

enum DigitalSaleStatus {
  ESPERANDO_PAGO
  COMPROBANTE_RECIBIDO
  PAGO_RECHAZADO
  ENTREGADO
  CANCELADO
}

enum ReceiptStatus {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
}

enum ProductFileType {
  IMAGE
  PDF
  VIDEO
  AUDIO
  OTHER
}

model Company {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String               @unique
  adminPhone       String
  timezone         String               @default("America/Lima")
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  users            User[]
  agentConfig      AgentConfig?
  whatsappConfig   WhatsappConfig?
  paymentConfig    PaymentConfig?
  products         Product[]
  customers        Customer[]
  messages         ConversationMessage[]
  orders            Order[]
  digitalSales      DigitalSale[]
  paymentReceipts   PaymentReceipt[]
  webhookEndpoints  WebhookEndpoint[]
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @db.Uuid
  name         String
  phone        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AgentConfig {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @unique @db.Uuid
  openaiModel String   @default("gpt-4o-mini")
  openaiApiKey String?
  temperature Decimal  @default(0.25) @db.Decimal(4, 2)
  basePrompt  String
  salesStyle  String
  rules       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model WhatsappConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String   @unique @db.Uuid
  apiUrl          String
  secret          String
  account         String?  @unique
  defaultServerId Int?
  smsToolsUserId  Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model PaymentConfig {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String          @unique @db.Uuid
  enabled           Boolean         @default(true)
  paymentMode       PaymentMode
  notificationPhone String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  methods           PaymentMethod[]
}

model PaymentMethod {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentConfigId String        @db.Uuid
  method          String
  number          String
  holder          String
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paymentConfig   PaymentConfig @relation(fields: [paymentConfigId], references: [id], onDelete: Cascade)

  @@index([paymentConfigId, sortOrder])
}

model Product {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String             @db.Uuid
  slug              String
  active            Boolean            @default(true)
  productType       ProductType
  name              String
  price             String
  regularPrice      String?
  stock             Int?
  shortDescription  String
  fullDescription   String
  deliveryMethod    String?
  support           String?
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aliases           ProductAlias[]
  benefits          ProductBenefit[]
  includes          ProductInclude[]
  bonuses           ProductBonus[]
  faqs              ProductFaq[]
  objections        ProductObjection[]
  files             ProductFile[]
  digitalDelivery   DigitalDelivery?
  physicalDelivery  PhysicalDelivery?
  variants          ProductVariant[]
  customers         Customer[]
  messages          ConversationMessage[]
  orders            Order[]
  digitalSales      DigitalSale[]
  paymentReceipts   PaymentReceipt[]

  @@unique([companyId, slug])
  @@index([companyId, active, sortOrder])
}

model ProductAlias {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  value     String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductBenefit {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  value     String
  sortOrder Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductInclude {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  value     String
  sortOrder Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductBonus {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  value     String
  sortOrder Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductFaq {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  question  String
  answer    String
  sortOrder Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductObjection {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  question  String
  answer    String
  sortOrder Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductFile {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String          @db.Uuid
  type         ProductFileType
  url          String
  storagePath  String          @default("")
  originalName String          @default("")
  extension    String          @default("")
  mimeType     String          @default("")
  size         Int             @default(0)
  description  String          @default("")
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model DigitalDelivery {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @unique @db.Uuid
  link         String
  instructions String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PhysicalDelivery {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String   @unique @db.Uuid
  requiresAddress Boolean  @default(true)
  deliveryCost    String?
  deliveryTime    String?
  pickupAvailable Boolean  @default(false)
  deliveryAreas   Json
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  name      String
  options   Json
  sortOrder Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Customer {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String                @db.Uuid
  phone             String
  name              String?
  email             String?
  status            String
  selectedProductId String?               @db.Uuid
  lastInteractionAt DateTime
  metadata          Json
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  selectedProduct   Product?              @relation(fields: [selectedProductId], references: [id], onDelete: SetNull)
  messages          ConversationMessage[]
  orders            Order[]
  digitalSales      DigitalSale[]
  paymentReceipts   PaymentReceipt[]

  @@unique([companyId, phone])
  @@index([companyId, lastInteractionAt])
}

model ConversationMessage {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String           @db.Uuid
  customerId String           @db.Uuid
  productId  String?          @db.Uuid
  role       ConversationRole
  message    String?
  mediaUrl   String?
  rawPayload Json?
  createdAt  DateTime         @default(now())
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId, customerId, createdAt])
}

model Order {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String      @db.Uuid
  customerId   String      @db.Uuid
  productId    String      @db.Uuid
  orderCode    String      @unique
  quantity     Int
  customerName String
  address      String
  reference    String
  notes        String?
  status       OrderStatus
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model DigitalSale {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String            @db.Uuid
  customerId     String            @db.Uuid
  productId      String            @db.Uuid
  amountExpected String
  status         DigitalSaleStatus
  deliveredAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  receipts       PaymentReceipt[]

  @@index([companyId, createdAt])
}

model PaymentReceipt {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String        @db.Uuid
  customerId      String?       @db.Uuid
  productId       String?       @db.Uuid
  productIds      String[]      @default([]) @db.Uuid
  orderId         String?
  digitalSaleId   String?       @db.Uuid
  mediaUrl        String?
  amountExpected  String        // mantenido por compatibilidad; mirror de amountPaid
  amountPaid      String?       // monto realmente recibido del origen
  currency        String        @default("PEN")
  status          ReceiptStatus
  rejectionReason String?
  source          String?       // "validpay", "manual", etc.
  externalId      String?       // id del pago en el sistema externo (idempotencia)
  payerName       String?       // nombre del pagador reportado por el origen
  paymentSource   String?       // "yape", "plin", "transferencia", etc.
  payerPhone      String?       // teléfono o últimos dígitos si el origen los emite
  operationCode   String?       // código de operación bancaria si aplica
  reference       String?       // referencia libre del origen
  occurredAt      DateTime?     // momento en que ocurrió el pago según el origen
  validatedAt     DateTime?     // momento en que se aprobó/rechazó
  validationNote  String?       // nota libre de quien validó (n8n / admin)
  validationMode  String?       // "AUTO" | "MANUAL"
  matchScore      Int?          // 0-100 score con que n8n lo cerró
  matchStrategy   String?       // ej: "amount_name_time"
  matchedPayerNameInput String? // nombre que envió el cliente vs el del comprobante
  metadata        Json?         // extras: conversationKey, waPhone, cartTotal, expectedAmount, etc.
  claimedBy       String?       // identificador de la ejecución n8n que reclamó el pago
  claimedUntil    DateTime?     // timestamp hasta el cual el claim es válido
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  digitalSale     DigitalSale?  @relation(fields: [digitalSaleId], references: [id], onDelete: SetNull)
  webhookEvents   WebhookEvent[]

  @@unique([source, externalId])
  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
  @@index([companyId, amountPaid])
  @@index([companyId, occurredAt])
}

model WebhookEndpoint {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @db.Uuid
  source         String   // "validpay", "mercadopago", "custom"
  secret         String   // plain text (almacenado en zona de confianza, igual que Stripe)
  active         Boolean  @default(true)
  autoApprove    Boolean  @default(true)
  description    String?
  validpayApiKey String?  // API Key de ValidPay para notificar de vuelta al aprobar (source=validpay)
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime?

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  events  WebhookEvent[]

  @@index([companyId])
  @@map("webhook_endpoints")
}

model WebhookEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  endpointId String   @db.Uuid
  companyId  String   @db.Uuid
  source     String
  externalId String
  payload    Json
  status     String   // RECEIVED, PROCESSED, FAILED, DUPLICATE
  error      String?
  receiptId  String?  @db.Uuid
  receivedAt DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  receipt  PaymentReceipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@unique([source, externalId])
  @@index([companyId, receivedAt])
  @@map("webhook_events")
}
