PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatsapp_admin?schema=public"
JWT_SECRET="super-secret-jwt"
JWT_EXPIRES_IN="7d"
BOT_CONFIG_API_KEY=""
# Si se define, POST /api/agent/inbound (webhook de WhatsApp del agente) exige header x-api-key
AGENT_INBOUND_API_KEY=""
# Turnos de historial que el agente envia a OpenAI por mensaje
AGENT_HISTORY_LIMIT=16
UPLOAD_DIR="uploads"
PUBLIC_BASE_URL="http://localhost:3000"
MAX_UPLOAD_MB=50

# SMS TOOLS admin API (used to provision a tenant account + API key)
SMSTOOLS_ADMIN_URL="https://smstools.pro/admin"
SMSTOOLS_ADMIN_TOKEN="your-smstools-admin-token-here"
SMSTOOLS_API_URL="https://smstools.pro/api/send/whatsapp"
