PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatsapp_admin?schema=public"
JWT_SECRET="super-secret-jwt"
JWT_EXPIRES_IN="7d"
BOT_CONFIG_API_KEY=""
# Si se define, POST /api/agent/inbound (webhook de WhatsApp del agente) exige header x-api-key
AGENT_INBOUND_API_KEY=""
# Turnos de historial que el agente envia a OpenAI por mensaje
AGENT_HISTORY_LIMIT=16
UPLOAD_DIR="uploads"
PUBLIC_BASE_URL="http://localhost:3000"
MAX_UPLOAD_MB=50

# SMS TOOLS admin API (used to provision a tenant account + API key)
SMSTOOLS_ADMIN_URL="https://smstools.pro/admin"
SMSTOOLS_ADMIN_TOKEN="your-smstools-admin-token-here"
SMSTOOLS_API_URL="https://smstools.pro/api/send/whatsapp"

# ─── API oficial de Meta (WhatsApp Cloud API) ──────────────────────────────
# Estas 3 variables son a NIVEL SISTEMA (una sola app de Meta para TODA la
# plataforma). NO son por cliente: cada tenant configura su token y su número
# desde el panel (WhatsApp API → API oficial de Meta), y eso se guarda en la BD.
#
# Version del Graph API de Meta (dejar el default salvo que Meta lo pida).
META_GRAPH_VERSION="v21.0"
# "App Secret" de TU app de Meta (Meta for Developers → tu App → Configuracion →
# Basico). Se usa para verificar la firma de los webhooks entrantes de Meta.
META_APP_SECRET=""
# Token que TU inventas y pegas en Meta al suscribir el webhook (cualquier texto
# secreto). Meta lo devuelve al verificar la URL; debe coincidir con este valor.
META_WEBHOOK_VERIFY_TOKEN=""
# Clave para cifrar en la BD los access tokens de Meta de cada cliente (AES-256).
# Genera una con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si se deja vacia, los tokens se guardan en texto plano (no recomendado).
CREDENTIALS_ENC_KEY=""
